{
  "name": "ldo",
  "description": "LDO voltage regulator circuit with input/output capacitors",
  "inputs": ["vin", "vout", "iout_max"],
  "components": [
    {
      "role": "regulator",
      "rules": ["ldo_dropout_check"]
    },
    {
      "role": "c_in",
      "lib": "Device:C",
      "value": "10uF",
      "rules": ["cap_voltage_derating"],
      "params": { "voperating": "$vin", "derating_factor": 2.0 }
    },
    {
      "role": "c_out",
      "lib": "Device:C",
      "value": "10uF",
      "rules": ["cap_voltage_derating"],
      "params": { "voperating": "$vout", "derating_factor": 2.0 }
    }
  ],
  "connections": [
    { "net": "VIN",  "pins": ["regulator.IN", "c_in.1"] },
    { "net": "GND",  "pins": ["regulator.GND", "c_in.2", "c_out.2"] },
    { "net": "VOUT", "pins": ["regulator.OUT", "c_out.1"] }
  ],
  "layout": {
    "regulator": { "x": 50.8, "y": 50.8 },
    "c_in": { "x": 33.02, "y": 50.8 },
    "c_out": { "x": 68.58, "y": 50.8 }
  }
}
