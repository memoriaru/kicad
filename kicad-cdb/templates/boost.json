{
  "name": "boost",
  "description": "Boost (step-up) converter circuit",
  "inputs": ["vin", "vout", "iout_max"],
  "components": [
    {
      "role": "controller",
      "rules": []
    },
    {
      "role": "l_in",
      "lib": "Device:L",
      "value": "10uH",
      "rules": ["boost_inductor_selection"],
      "params": { "vin": "$vin", "vout": "$vout", "iout": "$iout_max", "fsw": 500000, "ripple_ratio": 0.3 }
    },
    {
      "role": "c_in",
      "lib": "Device:C",
      "value": "10uF",
      "rules": ["cap_voltage_derating"],
      "params": { "voperating": "$vin", "derating_factor": 2.0 }
    },
    {
      "role": "c_out",
      "lib": "Device:C",
      "value": "22uF",
      "rules": ["boost_output_capacitor"],
      "params": { "iout": "$iout_max", "vin": "$vin", "vout": "$vout", "fsw": 500000, "ripple_v": 0.05 }
    },
    {
      "role": "d_out",
      "lib": "Device:D",
      "value": "SS34",
      "rules": ["boost_diode_voltage"],
      "params": { "vout": "$vout" }
    }
  ],
  "connections": [
    { "net": "VIN",  "pins": ["controller.VIN", "c_in.1", "l_in.1"] },
    { "net": "GND",  "pins": ["controller.GND", "c_in.2", "c_out.2"] },
    { "net": "SW",   "pins": ["controller.SW", "l_in.2", "d_out.A"] },
    { "net": "VOUT", "pins": ["d_out.K", "c_out.1"] }
  ],
  "layout": {
    "controller": { "x": 50.8,  "y": 50.8 },
    "c_in":       { "x": 33.02, "y": 50.8 },
    "l_in":       { "x": 33.02, "y": 33.02 },
    "d_out":      { "x": 76.2,  "y": 50.8 },
    "c_out":      { "x": 96.52, "y": 50.8 }
  }
}
